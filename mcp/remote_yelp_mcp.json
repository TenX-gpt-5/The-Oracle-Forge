{
  "servers": {
    "duckdb": {
      "command": "/home/gersum/.local/bin/mcp-server-duckdb",
      "args": [
        "--db-path",
        "/shared/DataAgentBench/query_yelp/query_dataset/yelp_user.db"
      ],
      "type": "stdio"
    },
    "mongodb": {
      "command": "npx",
      "args": [
        "-y",
        "mongodb-mcp-server@latest"
      ],
      "env": {
        "MDB_MCP_CONNECTION_STRING": "mongodb://localhost:27017/yelp_db"
      },
      "type": "stdio"
    }
  },
  "inputs": []
}
